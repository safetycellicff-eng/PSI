# Copy this file to .streamlit/secrets.toml and fill in ONE of the two
# backends below. If neither is configured, the app runs in local demo mode.

# ── Option A: Google Sheets (recommended — output lives in your sheet) ──────
# Paste the spreadsheet ID or the full URL of your Google Sheet.
spreadsheet_id = "PASTE_YOUR_SPREADSHEET_ID_OR_URL_HERE"

[gcp_service_account]
type = "service_account"
project_id = "your-project-id"
private_key_id = "..."
private_key = "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
client_email = "your-sa@your-project-id.iam.gserviceaccount.com"
client_id = "..."
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "..."

# ── Option B: Supabase (alternative backend) ────────────────────────────────
# Uncomment and fill in, and remove/leave-empty the section above.
# [supabase]
# url = "https://YOUR-PROJECT.supabase.co"
# key = "YOUR_SERVICE_ROLE_OR_ANON_KEY"
